{
  "name": "@neykoor/libsignal-node",
  "version": "1.0.5",
  "description": "TypeScript port of libsignal-node, compatible with BaileysX",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "prettier": "@neykoor/prettier-config/prettier",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./lib/*.js": {
      "types": "./lib/*.d.ts",
      "import": "./lib/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib/**/*"
  ],
  "scripts": {
    "build": "tsc -P tsconfig.json && tsc-esm-fix --tsconfig=tsconfig.json --ext=.js",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@neykoor/curve25519-ts": "^0.0.11",
    "pino": "^9.0.0",
    "protobufjs": "^7.5.5"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "@types/node": "22.9.3",
    "tsc-esm-fix": "^3.1.2",
    "@neykoor/prettier-config": "^0.1.2",
    "prettier": "^3.3.2",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
