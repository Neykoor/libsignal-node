{
	"name": "libsignal-node-ts",
	"version": "1.0.1",
	"description": "TypeScript port of libsignal-node, compatible with BaileysX",
	"type": "module",
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		},
		"./lib/*.js": {
			"types": "./lib/*.d.ts",
			"import": "./lib/*.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"lib/**/*"
	],
	"scripts": {
		"build": "tsc -P tsconfig.json && tsc-esm-fix --tsconfig=tsconfig.json --ext=.js"
	},
	"dependencies": {
		"curve25519-js": "^0.0.4",
		"pino": "^9.0.0",
		"protobufjs": "^7.5.5"
	},
	"devDependencies": {
		"typescript": "5.6.3",
		"@types/node": "22.9.3",
		"tsc-esm-fix": "^3.1.2"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
